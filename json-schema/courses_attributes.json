{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/kajabi/main/json-schema/courses_attributes.json",
  "title": "Courses",
  "description": "Schema for Kajabi courses",
  "type": "object",
  "properties": {
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "description": "ISO 8601 date-time, read only"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "thumbnail_url": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "title"
  ]
}